# ── Backend selection ─────────────────────────────────────────────────────────
DEFAULT_BACKEND=ollama          # lmstudio | ollama | claude | nvidia
DEFAULT_MODEL=                  # leave blank for auto-detect

# ── Local backends ────────────────────────────────────────────────────────────
LM_STUDIO_URL=http://localhost:1234/v1
OLLAMA_URL=http://localhost:11434/v1

# ── Cloud API keys ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# ── Generation settings ───────────────────────────────────────────────────────
TEMPERATURE=0.7
MAX_TOKENS=4096
