# LM Studio API endpoint (remote or local)
LM_STUDIO_URL=http://192.168.x.x:1234/v1

# Ollama endpoint (usually local)
OLLAMA_URL=http://localhost:11434/v1

# Default backend on startup: ollama | lmstudio | claude | nvidia
DEFAULT_BACKEND=ollama

# Default model (leave empty to auto-detect first loaded model)
DEFAULT_MODEL=

# Generation settings
TEMPERATURE=0.7
MAX_TOKENS=32752

# Stream tokens live to terminal (true/false)
STREAM=true

# ── API Keys (cloud backends) ────────────────────────────────────────────────

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# NVIDIA NIM — https://build.nvidia.com
NVIDIA_API_KEY=

# GitHub (for MCP github server)
GITHUB_TOKEN=

# Optional — other services
GEMINI_API_KEY=
GROQ_API_KEY=
ELEVENLABS_API_KEY=
